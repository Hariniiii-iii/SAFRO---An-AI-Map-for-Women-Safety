{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User's full name" },
        "photoURL": { "type": "string", "description": "Profile picture URL" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User access role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "SafetyReport": {
      "title": "Safety Report",
      "description": "A user-submitted safety observation in Trichy",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "type": { "type": "string", "enum": ["poor_lighting", "low_crowd", "isolated_area", "suspicious_activity", "safe_zone"] },
        "areaName": { "type": "string" },
        "description": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "verified", "archived"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "type", "lat", "lng", "timestamp"]
    },
    "SOSAlert": {
      "title": "SOS Alert",
      "description": "Active emergency alert",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "active": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "lat", "lng", "timestamp", "active"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Stores user profiles"
    },
    "/safety_reports/{reportId}": {
      "schema": "SafetyReport",
      "description": "Stores crowd-sourced safety data"
    },
    "/sos_alerts/{alertId}": {
      "schema": "SOSAlert",
      "description": "Stores active emergency signals"
    }
  }
}
