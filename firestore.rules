rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required, immutable)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string (enum: 'user', 'admin')
    //
    // Collection: safety_reports
    // Fields:
    //   - authorId: string (required, immutable)
    //   - type: string (enum)
    //   - areaName: string
    //   - description: string
    //   - lat: number
    //   - lng: number
    //   - status: string
    //   - timestamp: timestamp
    //
    // Collection: sos_alerts
    // Fields:
    //   - userId: string (required, immutable)
    //   - lat: number
    //   - lng: number
    //   - active: bool
    //   - timestamp: timestamp

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "itsmeharini612@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['authorId', 'type', 'lat', 'lng', 'timestamp']) &&
             data.authorId == request.auth.uid &&
             data.lat is number && data.lng is number &&
             data.type in ['poor_lighting', 'low_crowd', 'isolated_area', 'suspicious_activity', 'safe_zone'] &&
             data.description.size() < 1000;
    }

    function isValidSOS(data) {
      return data.keys().hasAll(['userId', 'lat', 'lng', 'timestamp', 'active']) &&
             data.userId == request.auth.uid &&
             data.lat is number && data.lng is number &&
             data.active is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.role == resource.data.role; // Prevent self-escalation
    }

    match /safety_reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidReport(request.resource.data);
      allow update: if isAdmin() || (isOwner(resource.data.authorId) && isValidReport(request.resource.data));
      allow delete: if isAdmin();
    }

    match /sos_alerts/{alertId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isAuthenticated() && isValidSOS(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin()) && isValidSOS(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
